# Security & JWT
SECRET_KEY=supersecretjwtkeyreplaceinproduction123456!
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MongoDB Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGO_DB_NAME=meeting_notes_db

# Vector DB Configuration
CHROMADB_DIR=./chroma_db

# LLM Providers (Provide at least one, or use mock)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Services Mocking (Set to true to skip active external API requirements during dev)
USE_MOCK_SERVICES=true

# Local server details
HOST=127.0.0.1
PORT=8000
